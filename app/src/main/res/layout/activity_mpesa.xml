<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:backgroundTint="#5D00BCD4"
    android:background="#11CAE2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MpesaActivity">

    <ImageView
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:src="@drawable/splash"
        android:scaleType="centerCrop"
        android:layout_margin="30dp"
        android:paddingLeft="60dp"
        android:id="@+id/product_photo"
        android:layout_marginLeft="30dp"

        />

    <TextView
        android:id="@+id/product_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Product Name"
        android:textColor="#077481"
        android:fontFamily="sans-serif-condensed-light"
        android:textSize="24dp"
        android:layout_marginLeft="20dp"
        android:paddingTop="20dp"
        />

    <TextView
        android:id="@+id/product_cost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ksh 0"
        android:textSize="20dp"
        android:textColor="#F4F4F4"
        android:layout_marginLeft="20dp"
        android:layout_marginBottom="20dp"
        android:layout_marginTop="10dp"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This is the best product you will see in our app"
        android:id="@+id/product_description"
        android:textStyle="italic"
        android:textColor="#EFE3E3"
        android:textSize="24sp"
        android:layout_marginBottom="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp"


        />

    <EditText
        android:id="@+id/phone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter Phone +254"
        android:background="@drawable/edittext"
        android:inputType="number"
        android:layout_marginLeft="30dp"
        android:layout_marginRight="150dp"
        android:paddingTop="15dp"
        android:paddingBottom="20dp"
        android:textColor="#000000"

        />

    <Button
        android:id="@+id/purchase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PURCHASE"
        android:textStyle="italic"
        android:backgroundTint="#03A9F4"
        android:textColor="@color/white"
        android:layout_margin="30dp"
        android:layout_marginRight="20dp"
        android:layout_marginLeft="50dp"
        android:padding="2dp"

        />
</LinearLayout>